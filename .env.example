APP_NAME="ITAF Badging"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=itaf_badging
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="badging@itaf-events.ma"
MAIL_FROM_NAME="${APP_NAME}"

# Nom de l'événement affiché partout
EVENT_NOM="ITAF 2026"
EVENT_DATE="15 Juin 2026"
EVENT_LIEU="Centre de Conférences, Casablanca"
EVENT_SLUG=itaf-2026

# Imprimante thermique ESC/POS
IMPRIMANTE_TYPE=file
IMPRIMANTE_CIBLE=/dev/usb/lp0

# Identifiant du kiosque (pour traçabilité des scans)
KIOSQUE_ID=kiosque-1
